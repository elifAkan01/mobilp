<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HesapMakinesiApp.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="RakamBtn" TargetType="Button">
                <Setter Property="BackgroundColor" Value="#1C1C1C" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="FontSize" Value="24" />
                <Setter Property="CornerRadius" Value="40" />
                <Setter Property="HeightRequest" Value="20" />
                <Setter Property="WidthRequest" Value="20" />
            </Style>

            <Style x:Key="BilimselBtn" TargetType="Button">
                <Setter Property="BackgroundColor" Value="#333333" />
                <Setter Property="TextColor" Value="#A5A5A5" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="CornerRadius" Value="40" />
            </Style>

            <Style x:Key="IslemBtn" TargetType="Button">
                <Setter Property="BackgroundColor" Value="#FF9500" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="FontSize" Value="28" />
                <Setter Property="CornerRadius" Value="40" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>