<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HesapMakinesiApp.MainPage">

    <Grid Padding="10"
          RowDefinitions="2*,1*,1*,1*,1*,1*,1*"
          ColumnDefinitions="*,*,*,*,*">

        <Label x:Name="lblSonuc"
               Grid.Row="0"
               Grid.ColumnSpan="5"
               Text="0"
               FontSize="55"
               HorizontalTextAlignment="End"
               VerticalTextAlignment="End"/>

        <Label x:Name="lblIslem"
               Grid.Row="1"
               Grid.ColumnSpan="5"
               Text=""
               FontSize="24"
               HorizontalTextAlignment="End"
               TextColor="Gray"/>

        <Button Text="C" Grid.Row="2" Grid.Column="0" Clicked="Temizle"/>
        <Button Text="⌫" Grid.Row="2" Grid.Column="1" Clicked="Sil"/>
        <Button Text="%" Grid.Row="2" Grid.Column="2" Clicked="Operator_Clicked"/>
        <Button Text="/" Grid.Row="2" Grid.Column="3" Clicked="Operator_Clicked"/>

        <Button Text="="
                Grid.Row="2"
                Grid.Column="4"
                Grid.RowSpan="5"
                BackgroundColor="Orange"
                Clicked="Esittir"/>

        <Button Text="7" Grid.Row="3" Grid.Column="0" Clicked="Rakam_Clicked"/>
        <Button Text="8" Grid.Row="3" Grid.Column="1" Clicked="Rakam_Clicked"/>
        <Button Text="9" Grid.Row="3" Grid.Column="2" Clicked="Rakam_Clicked"/>
        <Button Text="*" Grid.Row="3" Grid.Column="3" Clicked="Operator_Clicked"/>

        <Button Text="4" Grid.Row="4" Grid.Column="0" Clicked="Rakam_Clicked"/>
        <Button Text="5" Grid.Row="4" Grid.Column="1" Clicked="Rakam_Clicked"/>
        <Button Text="6" Grid.Row="4" Grid.Column="2" Clicked="Rakam_Clicked"/>
        <Button Text="-" Grid.Row="4" Grid.Column="3" Clicked="Operator_Clicked"/>

        <Button Text="1" Grid.Row="5" Grid.Column="0" Clicked="Rakam_Clicked"/>
        <Button Text="2" Grid.Row="5" Grid.Column="1" Clicked="Rakam_Clicked"/>
        <Button Text="3" Grid.Row="5" Grid.Column="2" Clicked="Rakam_Clicked"/>
        <Button Text="+" Grid.Row="5" Grid.Column="3" Clicked="Operator_Clicked"/>

        <Button Text="0" Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Clicked="Rakam_Clicked"/>
        <Button Text="." Grid.Row="6" Grid.Column="2" Clicked="Rakam_Clicked"/>

    </Grid>

</ContentPage>